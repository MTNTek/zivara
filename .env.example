# =============================================================================
# Zivara Environment Configuration
# =============================================================================
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to version control.
# =============================================================================

# Database (Neon / PostgreSQL)
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Auth — MUST be a strong random string in production (min 32 chars)
# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Stripe (payment processing)
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Resend (transactional email)
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=noreply@yourdomain.com

# CDN / Storage (optional — for production image hosting)
# CDN_HOSTNAME=cdn.yourdomain.com
# STORAGE_URL=https://cdn.yourdomain.com

# Sentry (optional — error tracking)
# SENTRY_DSN=https://...@sentry.io/...
